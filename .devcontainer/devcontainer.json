{
  "name": "Python & MySQL Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  
  // Install project dependencies and MySQL CLI tools.
  "postCreateCommand": "pip install -r requirements.txt && sudo apt-get update && sudo apt-get install -y default-mysql-client",

  // Adds useful tools for interacting with MySQL
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql"
      ]
    }
  }
}